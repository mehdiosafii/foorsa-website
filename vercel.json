{
  "functions": {
    "api/submit-form.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/*.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/admin/*.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/uploads/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/universities-in-china/:path*",
      "destination": "/en/:path*",
      "statusCode": 301
    },
    {
      "source": "/scholarships/:path*",
      "destination": "/en/:path*",
      "statusCode": 301
    },
    {
      "source": "/:path*(/)",
      "destination": "/:path*",
      "statusCode": 301
    }
  ],
  "trailingSlash": false
}